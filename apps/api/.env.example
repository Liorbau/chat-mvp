PORT=4000
CORS_ORIGIN=http://localhost:5173

# Required: secret used to sign and verify JWTs. The app fails to start if unset.
JWT_SECRET=change-me-in-local-and-prod
# Optional: JWT lifetime (vercel/ms format). Defaults to 1h.
JWT_EXPIRES_IN=1h
# Required: bcrypt cost factor for password hashing (use 10-12 in production).
# The app fails to start if unset.
BCRYPT_ROUNDS=12
